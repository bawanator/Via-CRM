# --- Supabase (new project in the existing Vía Private Supabase org) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Used by Gmail cron sync, the MCP server, seed and import scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Google OAuth (same client used by Supabase Auth; needed to refresh Gmail tokens) ---
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# --- Gmail sync (read-only) ---
# true = sign-in requests the gmail.readonly scope and the Gmail sync UI shows.
# Requires the Gmail API enabled in the Google Cloud project; after flipping
# this on, sign out and back in once to grant the scope.
NEXT_PUBLIC_ENABLE_GMAIL_SYNC=true

# --- Vercel cron auth (any long random string; Vercel sends it as a Bearer token) ---
CRON_SECRET=generate-a-long-random-string

# --- MCP server (scoped key: this is the only secret the MCP process needs beyond Supabase) ---
# Email of the allowlisted user the MCP server acts as (audit rows attribute to them).
MCP_ACTOR_EMAIL=harry@viaprivate.com.au

# --- Gmail contact discovery (reply-triggered skeleton contacts) ---
# Off unless explicitly "true". Thread sync of existing contacts still runs.
ENABLE_GMAIL_DISCOVERY=false

# --- Google Tasks two-way sync ---
# Off unless explicitly "true" (default false; enable in Vercel when ready).
# CRM tasks mirror into a "Vía OS" Google Tasks list (visible in the Google
# Tasks & Calendar apps); the nightly cron pulls Google-side completions back.
# Requires the Google Tasks API enabled in the Cloud project and one
# sign-out/sign-in after NEXT_PUBLIC_ENABLE_GMAIL_SYNC to grant the scope.
ENABLE_GOOGLE_TASKS_SYNC=false

# --- Meeting note prompts (calendar.readonly) ---
# Off unless explicitly "true" (default false; enable in Vercel when ready).
# The nightly cron scans primary-calendar events that ended in the past 24h
# and creates an "Add notes from …" task for meetings with external attendees.
# Requires the Google Calendar API enabled in the Cloud project.
ENABLE_MEETING_TASK_PROMPTS=false
